---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.scss";
import { AstroFont } from "astro-font";
import { ViewTransitions } from "astro:transitions";

// font families
const pf = theme.fonts.font_family.primary;
const sf = theme.fonts.font_family.secondary;

let fontPrimary, fontSecondary;
if (theme.fonts.font_family.primary) {
  fontPrimary = theme.fonts.font_family.primary.replace(/\+/g, " ").replace(/:[ital,]*[ital@]*[wght@]*[0-9,;]+/gi, "");
}
if (theme.fonts.font_family.secondary) {
  fontSecondary = theme.fonts.font_family.secondary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;]+/gi, "");
}

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  external_image?: boolean;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  date?: string;
  tags?: list;
  weight?: number;
}

// distructure frontmatters
const { title, meta_title, description, image, noindex, canonical, date, tags, weight, external_image } = Astro.props;

// resolved metadata helpers
const pageTitle = plainify(meta_title ? meta_title : title ? title : config.site.title).trim();
const pageDescription = plainify(description ? description : config.metadata.meta_description).trim();
const canonicalURL = canonical || new URL(Astro.url.pathname, config.site.base_url).href;
const ogImage = encodeURI(
  `${!external_image ? config.site.base_url : ""}${image ? image : config.metadata.meta_image}`,
);
// a page with a date is a blog article, otherwise a regular page
const isArticle = !!date;
const publishedISO = date ? new Date(date).toISOString() : undefined;

// structured data (JSON-LD)
const organization = {
  "@type": "Organization",
  "@id": `${config.site.base_url}/#organization`,
  name: config.site.title,
  url: config.site.base_url,
  logo: {
    "@type": "ImageObject",
    url: `${config.site.base_url}${config.site.logo}`,
  },
  sameAs: [
    "https://www.instagram.com/ciarasclassroom",
    "https://www.facebook.com/ciarasclassroom/",
    "https://ie.pinterest.com/ciarasclassroom",
    "https://www.tiktok.com/@ciarasclassroom",
    "https://ie.linkedin.com/in/ciarasclassroom",
    "https://www.teacherspayteachers.com/Store/Ciaras-Classroom",
  ],
};

const website = {
  "@type": "WebSite",
  "@id": `${config.site.base_url}/#website`,
  url: config.site.base_url,
  name: config.site.title,
  description: config.metadata.meta_description,
  publisher: { "@id": `${config.site.base_url}/#organization` },
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${config.site.base_url}/search?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};

const graph: any[] = [organization, website];

if (isArticle) {
  graph.push({
    "@type": "BlogPosting",
    "@id": `${canonicalURL}#article`,
    mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
    headline: pageTitle,
    description: pageDescription,
    image: ogImage,
    datePublished: publishedISO,
    dateModified: publishedISO,
    author: {
      "@type": "Person",
      name: "Ciara Lynch",
      url: `${config.site.base_url}/about`,
    },
    publisher: { "@id": `${config.site.base_url}/#organization` },
    ...(tags && tags.length ? { keywords: tags.join(", ") } : {}),
  });
}

const jsonLd = JSON.stringify({ "@context": "https://schema.org", "@graph": graph });
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={config.site.title} href="/rss.xml" />

    <!-- speed up google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta name="google-site-verification" content="-OBHGm_Nls9yR0u8lq1aqZLYDFw_dUU1qwfFT5vfVFg" />
    <meta name="p:domain_verify" content="3f05bbb83118856ab395237ec971d550" />

    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css -->
    <AstroFont
      config={[
        {
          src: [],
          preload: false,
          display: "swap",
          name: fontPrimary!,
          fallback: "sans-serif",
          cssVariable: "font-primary",
          googleFontsURL: `https://fonts.googleapis.com/css2?family=${pf}&display=swap`,
        },
        {
          src: [],
          preload: false,
          display: "swap",
          name: fontSecondary!,
          fallback: "sans-serif",
          cssVariable: "font-secondary",
          googleFontsURL: `https://fonts.googleapis.com/css2?family=${sf}&display=swap`,
        },
      ]}
    />

    <!-- responsive meta -->
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />

    <!-- title -->
    <title>{pageTitle}</title>

    <!-- canonical url -->
    <link rel="canonical" href={canonicalURL} />

    <!-- meta-description -->
    <meta name="description" content={pageDescription} />

    <meta name="keywords" content={tags ? tags.join(", ") : config.metadata.meta_tags.join(", ")} />

    <ViewTransitions />

    <!-- author -->
    <meta name="author" content={isArticle ? "Ciara Lynch" : config.metadata.meta_author} />

    <!-- robots -->
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="language" content="English" />

    <!-- og-title -->
    <meta property="og:title" content={pageTitle} />

    <!-- og-description -->
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={config.site.title} />
    <meta property="og:locale" content="en_IE" />

    <!-- article meta -->
    {isArticle && publishedISO && <meta property="article:published_time" content={publishedISO} />}
    {isArticle && publishedISO && <meta property="article:modified_time" content={publishedISO} />}
    {isArticle && <meta property="article:author" content="Ciara Lynch" />}
    {isArticle && tags && tags.map((tag: string) => <meta property="article:tag" content={tag} />)}

    <!-- twitter-title -->
    <meta name="twitter:title" content={pageTitle} />

    <!-- twitter-description -->
    <meta name="twitter:description" content={pageDescription} />

    <!-- og-image -->
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={pageTitle} />

    <!-- twitter-image -->
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- structured data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=1723991838" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=1723991838" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=1723991838" />
    <link rel="manifest" href="/site.webmanifest?v=1723991838" />
    <link rel="shortcut icon" href="/favicon.ico?v=1723991838" />
    <meta name="msapplication-TileColor" content="#ffffff" />
    <meta name="theme-color" content="#ffffff" />
  </head>
  <body>
    <TwSizeIndicator />
    <Header />
    <main id="main-content" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
    <!-- Google Analytics 4 (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H0SPRG8BKN"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-H0SPRG8BKN", { anonymize_ip: true });
    </script>
    <!-- track client-side navigations from Astro View Transitions -->
    <script>
      document.addEventListener("astro:page-load", () => {
        if (typeof window.gtag === "function") {
          window.gtag("event", "page_view", {
            page_path: window.location.pathname + window.location.search,
            page_location: window.location.href,
            page_title: document.title,
          });
        }
      });
    </script>
  </body>
</html>
